{
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/nft",
      "destination": "api/nft.js"
    },
    {
      "source": "/api/chat",
      "destination": "api/chat.js"
    },
    {
      "source": "/api/ticker",
      "destination": "api/ticker.js"
    },
    {
      "source": "/api/xaman",
      "destination": "api/xaman.js"
    },
    {
      "source": "/api/callback",
      "destination": "api/callback.js"
    },
    {
      "source": "/api/fusion-gate",
      "destination": "api/fusion-gate.js"
    }
  ],
  "redeploy": "5"
}