{
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/api/nft", "destination": "/api/nft.js" },
    { "source": "/api/chat", "destination": "/api/chat.js" },
    { "source": "/api/xaman", "destination": "/api/xaman.js" },
    { "source": "/(.*)", "destination": "/$1" }
  ]
}